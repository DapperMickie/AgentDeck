<Router AppAssembly="typeof(Routes).Assembly"
        AdditionalAssemblies="@(new[] { typeof(AgentDeck.Core._Imports).Assembly })">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(AgentDeck.Core.Layout.MainLayout)" />
    </Found>
    <NotFound>
        <LayoutView Layout="typeof(AgentDeck.Core.Layout.MainLayout)">
            <p role="status">Page not found.</p>
        </LayoutView>
    </NotFound>
</Router>
