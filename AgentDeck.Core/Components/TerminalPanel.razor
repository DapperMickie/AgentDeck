@inject TerminalInterop TerminalJs
@inject IRunnerConnectionManager Connections
@implements IAsyncDisposable

<div class="terminal-panel @(IsActive ? "terminal-panel--active" : "")"
     id="panel-@Session.Id">
    <div class="terminal-host" id="@_containerId"></div>
</div>

@code {
    [Parameter, EditorRequired] public TerminalSession Session { get; set; } = null!;
    [Parameter] public bool IsActive { get; set; }

    private string _containerId = string.Empty;
    private DotNetObjectReference<TerminalPanel>? _dotnetRef;
    private bool _initialised;

    protected override void OnParametersSet()
    {
        _containerId = $"xterm-{Session.Id}";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialised) return;
        _initialised = true;

        _dotnetRef = DotNetObjectReference.Create(this);
        await TerminalJs.CreateTerminalAsync(_containerId, Session.Id, _dotnetRef);
        await Connections.JoinSessionAsync(Session.Id);
        Connections.OutputReceived += OnOutputReceived;

        // Fit to the actual container dimensions and explicitly resize the PTY.
        // This is critical: the PTY starts at the CreateTerminalRequest default
        // (80×24). Without an explicit resize, copilot reads its terminal width
        // on startup as 80 cols and never redraws at the correct width.
        var size = await TerminalJs.FitAndGetSizeAsync(Session.Id);
        if (size.HasValue)
            await Connections.ResizeTerminalAsync(Session.Id, size.Value.Cols, size.Value.Rows);

        await TerminalJs.FocusAsync(Session.Id);
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_initialised && IsActive)
        {
            // Re-fit when this tab becomes visible (window may have been resized
            // while this panel was hidden) and push the new size to the runner.
            var size = await TerminalJs.FitAndGetSizeAsync(Session.Id);
            if (size.HasValue)
                await Connections.ResizeTerminalAsync(Session.Id, size.Value.Cols, size.Value.Rows);
            await TerminalJs.FocusAsync(Session.Id);
        }
    }

    private void OnOutputReceived(object? sender, TerminalOutput output)
    {
        if (output.SessionId != Session.Id) return;
        _ = InvokeAsync(async () =>
        {
            try { await TerminalJs.WriteAsync(Session.Id, output.Data); }
            catch { /* component disposed or JS interop unavailable */ }
        });
    }

    /// <summary>Called from JS when the user types in the terminal.</summary>
    [JSInvokable]
    public async Task OnTerminalInput(string data)
    {
        await Connections.SendInputAsync(Session.Id, data);
    }

    /// <summary>Called from JS when the terminal is resized.</summary>
    [JSInvokable]
    public async Task OnTerminalResize(int cols, int rows)
    {
        await Connections.ResizeTerminalAsync(Session.Id, cols, rows);
    }

    public async ValueTask DisposeAsync()
    {
        Connections.OutputReceived -= OnOutputReceived;

        if (_initialised)
        {
            await Connections.LeaveSessionAsync(Session.Id);
            await TerminalJs.DisposeTerminalAsync(Session.Id);
        }

        _dotnetRef?.Dispose();
    }
}
