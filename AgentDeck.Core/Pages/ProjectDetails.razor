    private string GetUnavailableMachineStatusMessage(ProjectLaunchProfile profile)
    {
        var viewerSurfaceSummary = GetRequiredViewerSurfaceSummary(profile);
        var incompatibleCount = _dashboard.Machines.Count(machine =>
            machine.IsOnline &&
            !machine.ProtocolCompatible &&
            ProjectLaunchReadiness.SupportsLaunchProfile(profile, machine.SupportedTargets, machine.RemoteViewerProviders));

        var missingViewerSurfaceCount = _dashboard.Machines.Count(machine =>
            machine.IsOnline &&
            machine.ProtocolCompatible &&
            ProjectLaunchReadiness.SupportsPlatform(profile, machine.SupportedTargets) &&
            ProjectLaunchReadiness.GetMissingViewerTargets(profile, machine.RemoteViewerProviders).Count > 0);

        if (incompatibleCount > 0)
        {
            return $"No protocol-compatible machine currently advertises {profile.Platform} with {viewerSurfaceSummary}. {incompatibleCount} matching machine(s) are blocked by protocol compatibility.";
        }

        if (missingViewerSurfaceCount > 0)
        {
            return $"No ready machine currently advertises {profile.Platform} with {viewerSurfaceSummary}. {missingViewerSurfaceCount} matching machine(s) are missing at least one required viewer surface.";
        }

        return $"No ready machine currently advertises {profile.Platform}.";
    }

    private static string? GetProjectWorkflowNotice(CompanionMachineSummary machine)
    {
        if (!machine.ProtocolCompatible)
        {
            return "Coordinator-managed project actions are disabled until this runner's protocol compatibility is restored.";
        }

        if (machine.WorkflowCatalogStatus?.State == RunnerWorkflowCatalogState.Mismatched)
        {
            return "The runner workflow catalog does not match the coordinator's desired version.";
        }

        if (machine.WorkflowPackStatus?.State == RunnerWorkflowPackState.Failed)
        {
            return "The assigned workflow pack last failed on this runner. Retry or repair setup before relying on it for project work.";
        }

        if (machine.WorkflowPackStatus?.State == RunnerWorkflowPackState.Blocked)
        {
            return "The assigned workflow pack is currently blocked by control-plane policy or local machine state.";
        }

        if (machine.UpdateRollout is { State: RunnerUpdateRolloutState.Blocked })
        {
            return "Runner update rollout is currently blocked for this machine.";
        }

        if (machine.UpdateRollout is { State: RunnerUpdateRolloutState.Failed })
        {
            return "Runner update rollout last failed on this machine.";
        }

        return null;
    }

