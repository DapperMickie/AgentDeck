@page "/"
@inject IAgentDeckClient Client
@inject ISessionStateService SessionState
@implements IDisposable

<div class="dashboard">
    @if (SessionState.Sessions.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-icon">⬡</div>
            <h2>No active terminals</h2>
            <p>
                @if (Client.ConnectionState != HubConnectionState.Connected)
                {
                    <span>Connect to a runner in <a href="/settings">Settings</a> to get started.</span>
                }
                else
                {
                    <span>Create a new terminal session to get started.</span>
                }
            </p>
        </div>
    }
    else
    {
        <!-- Tab bar -->
        <div class="tab-bar">
            @foreach (var session in SessionState.Sessions)
            {
                <button class="tab @(IsActiveSession(session.Id) ? "tab--active" : "")"
                        @onclick="() => SelectSession(session.Id)">
                    <span class="tab-status-dot tab-status-dot--@session.Status.ToString().ToLower()"></span>
                    <span class="tab-name">@session.Name</span>
                    <button class="tab-close" @onclick:stopPropagation="true"
                            @onclick="() => CloseSessionAsync(session.Id)"
                            title="Close @session.Name">✕</button>
                </button>
            }
        </div>

        <!-- Terminal panels (one per session, only active is visible) -->
        <div class="terminal-area">
            @foreach (var session in SessionState.Sessions)
            {
                <TerminalPanel Session="session" IsActive="IsActiveSession(session.Id)" />
            }
        </div>
    }
</div>

@code {
    private string? _activeSessionId;

    protected override void OnInitialized()
    {
        Client.ConnectionStateChanged += OnStateChanged;
        SessionState.SessionsChanged += OnSessionsChanged;
    }

    protected override void OnParametersSet()
    {
        EnsureActiveSession();
    }

    private void EnsureActiveSession()
    {
        if (_activeSessionId is null || !SessionState.Sessions.Any(s => s.Id == _activeSessionId))
            _activeSessionId = SessionState.Sessions.FirstOrDefault()?.Id;
    }

    private bool IsActiveSession(string id) => id == _activeSessionId;

    private void SelectSession(string id)
    {
        _activeSessionId = id;
    }

    private async Task CloseSessionAsync(string sessionId)
    {
        await Client.CloseSessionAsync(sessionId);
        EnsureActiveSession();
    }

    private void OnStateChanged(object? sender, HubConnectionState _) =>
        InvokeAsync(StateHasChanged);

    private void OnSessionsChanged(object? sender, EventArgs _)
    {
        EnsureActiveSession();
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Client.ConnectionStateChanged -= OnStateChanged;
        SessionState.SessionsChanged -= OnSessionsChanged;
    }
}
